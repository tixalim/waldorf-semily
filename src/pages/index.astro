---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Domů">

  <!-- HERO + KARTY společně přes pozadí -->
  <div class="hero-wrapper">
    <img class="hero-bg" src="/waldorf-semily/images/purple.jpeg" alt="mandala" />
    
    <!-- HERO -->
    <section class="hero">
        <h1>Cesta <br />druhým <br />a třetím sedmiletím</h1>
        <div class="hero-vedlejsi">
            <p>Abychom vychovali celé dítě, musíme oslovit nejenom jeho rozum <br /> ale i vůli a srdce.</p>
            <div class="hero-odkazy">
            <a href="/waldorf-semily/dokumenty">DOKUMENTY</a>
            <a href="/waldorf-semily/zakladni-skola/jak-ucime">JAK UČÍME</a>
            </div>
        </div>
    </section>

    <!-- KARTY -->
    <section class="karty">
      <a href="/waldorf-semily/zakladni-skola" class="karta karta-zs">
        <span>1. - 9. třída</span>
        <h2>Základní škola</h2>
        <p>Celostní vzdělávání.<br />Hlava, srdce i ruce.<br />Rytmus, který odpovídá vývoji dítěte.</p>
        <span class="karta-link">VÍCE O ZÁKLADNÍ ŠKOLE</span>
      </a>
      <a href="/waldorf-semily/lyceum" class="karta karta-ss">
        <span>Waldorfské Lyceum</span>
        <h2>Střední škola</h2>
        <p>Všeobecné vzdělání zakončené maturitou.<br />Široký rozhled - umění a řemeslo.<br />Prostor pro vlastní rozvoj.<br />Důraz na celého člověka.</p>
        <span class="karta-link">VÍCE O STŘEDNÍ ŠKOLE</span>
      </a>
    </section>
  </div>

  <!-- AKTUALITY -->
    <section class="aktuality">
    <h2>Co se u nás děje?</h2>
    <div class="aktuality-grid">
        <a href="/waldorf-semily/aktuality" class="aktualita aktualita-zs">
        <span>ZŠ</span>
        <h3>Den otevřených dveří</h3>
        <p class="datum">15. Dubna 2026</p>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
        </a>
        <a href="/waldorf-semily/aktuality" class="aktualita aktualita-ss">
        <span>SŠ</span>
        <h3>Výsledky přijímacího řízení 2026/27</h3>
        <p class="datum">1. Května 2026</p>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
        </a>
        <a href="/waldorf-semily/aktuality" class="aktualita aktualita-cela">
        <span>Celá škola</span>
        <h3>Jarní slavnost</h3>
        <p class="datum">10. Března 2026</p>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
        </a>
    </div>
    <a href="/waldorf-semily/aktuality" class="vsechny-aktuality">VŠECHNY AKTUALITY</a>
    </section>
</Layout>

<style>
  /* HERO WRAPPER - společné pozadí pro hero i karty */
  .hero-wrapper {
    position: relative;
    padding: 0 8rem;
    max-width: 100vw;
  }

  .hero-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 2600px;
  height: auto;
  object-fit: contain;
  z-index: 0;
  transform: translate(-43%, -45%) rotate(-150deg);
}


  /* HERO */
    .hero {
    position: relative;
    z-index: 1;
    padding: 2rem 0 10rem;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    gap: 3rem;
    }

    .hero h1 {
    font-family: Waldorf;
    font-size: 90px;
    line-height: 1.2;
    flex-shrink: 0;
    max-width: 500px;
    }

    .hero-vedlejsi {
    padding-top: 17rem;
    padding-left: 6rem;
    }

    .hero p {
    font-size: 20px;
    font-weight: 600;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 300px;
    }

    .hero-odkazy {
    display: flex;
    gap: 3rem;
    }

  .hero-odkazy a {
    text-decoration: none;
    color: #1a1a1a;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .hero-odkazy a:hover {
    color: var(--fialova);
  }

  /* KARTY */
  .karty {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    padding: 2rem 0 6rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .karta {
    border-radius: 16px;
    padding: 2rem;
    text-decoration: none;
    color: #1a1a1a;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.2s;
  }

  .karta:hover {
    transform: translateY(-4px);
  }

  .karta-zs {
    background: var(--cervena-svetla);
  }

  .karta-ss {
    background: var(--modra-svetla);
  }

  .karta span {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .karta h2 {
    font-family: Waldorf;
    font-size: 40px;
    margin: 0.25rem 0;
  }

  .karta p {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.8;
    flex-grow: 1;
  }

  .karta-link {
    font-size: 17px !important;
    font-weight: 600 !important;
    letter-spacing: 0.08em;
    margin-top: 1rem;
  }

  /* AKTUALITY */
  .aktuality {
    position: relative;
    padding: 4rem 20rem;
    text-align: center;
    z-index: 1;
  }

  .aktuality h2 {
    font-family: Waldorf;
    font-size: 50px;
    margin-bottom: 3rem;
  }

  .aktuality-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
    text-align: left;
    margin-bottom: 2rem;
  }

  .aktualita {
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: #1a1a1a;
    display: grid;
    grid-template-rows: auto auto auto 1fr;
    transition: transform 0.2s;
  }

  .aktualita:hover {
  transform: translateY(-4px);
    }

  .aktualita-zs {
    background: var(--cervena-svetla);
    
  }

  .aktualita-ss {
    background: var(--modra-svetla);
    
  }

  .aktualita-cela {
    background: var(--fialova-svetla);
    
  }

  .aktualita span {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .aktualita h3 {
    font-size: 22px;
    margin: 1.5rem 0 1rem;
    min-height: 55px;
  }

  .datum {
    font-weight: 600;
    font-size: 17px;
    margin-bottom: 1rem;
  }

  .aktualita p {
    font-size: 17px;
    line-height: 1.6;
  }

  .vsechny-aktuality {
    display: block;
    text-decoration: none;
    color: #1a1a1a;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0.08em;
    margin-top: 3rem;
  }

  .vsechny-aktuality:hover {
    color: var(--fialova);
  }

  @media (max-width: 1024px) {
  .hero-wrapper {
    padding: 0 3rem;
  }

  .hero {
    flex-direction: column;
    padding: 2rem 0 4rem;
    gap: 1rem;
  }

  .hero h1 {
    font-size: 60px;
  }

  .hero-vedlejsi {
    padding-top: 0;
    padding-left: 0;
  }

  .karty {
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 2rem 0 4rem;
  }

  .aktuality {
    padding: 3rem 3rem;
  }

  .aktuality-grid {
    grid-template-columns: 1fr;
  }

  .aktuality h2 {
    font-size: 36px;
  }
}

@media (max-width: 768px) {
  .hero-wrapper {
    padding: 0 1.5rem;
  }

  .hero h1 {
    font-size: 44px;
  }

  .aktuality {
    padding: 2rem 1.5rem;
  }
}
</style>