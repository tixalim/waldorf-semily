---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Družina" barvFooteru="var(--cervena-svetla)">
  <!-- BREADCRUMB -->
  <nav class="breadcrumb">
    <a href="/waldorf-semily/">ÚVOD</a>
    <span> - </span>
    <a href="/waldorf-semily/zakladni-skola">ZÁKLADNÍ ŠKOLA</a>
    <span> - </span>
    <span>DRUŽINA</span>
  </nav>

  <!-- WRAPPER s mandálou přes celý obsah -->
  <div class="druzina-wrapper">
    <img
      class="druzina-bg"
      src="/waldorf-semily/images/red.jpeg"
      alt="červená mandala"
    />

    <!-- HERO -->
    <section class="druzina-hero">
      <h1>Školní<br />družina</h1>
      <div class="druzina-vedlejsi">
        <p>
          Bezpečné a podnětné místo pro vaše děti před i po vyučování.
          Odpočinek, hra i tvořivé aktivity.
        </p>
      </div>
    </section>

    <!-- PROVOZ -->
    <section class="sekce dvousloupec">
      <div class="blok">
        <h2>Provozní doba</h2>
        <div class="provoz-grid">
          <div class="provoz-karta">
            <span class="provoz-cas"> 7:00 až 8:00</span>
            <p>Ranní družina před vyučováním</p>
          </div>
          <div class="provoz-karta">
            <span class="provoz-cas">Po výuce do 16:00</span>
            <p>Odpolední družina</p>
          </div>
        </div>
        <p class="poznamka">
          Kapacita 72 žáků. Přednostně přijímáni žáci 1.–3. třídy s celotýdenní
          docházkou.
        </p>
      </div>
    </section>

    <!-- VYZVEDÁVÁNÍ + ZÁPIS -->
    <section class="sekce sekce-alt dvousloupec">
      <div class="blok">
        <h2>Vyzvedávání</h2>
        <div class="vyzvednuti-grid">
          <div class="vyzvednuti-item">
            <span>Po vyučování</span><p>Dle rozvrhu třídy</p>
          </div>
          <div class="vyzvednuti-item">
            <span>Po obědě</span><p>Cca 30 min po výuce</p>
          </div>
          <div class="vyzvednuti-item">
            <span>Do 13:00</span><p>Před venkovními aktivitami</p>
          </div>
          <div class="vyzvednuti-item">
            <span>Po 14:00</span><p>Po odpočinkové části</p>
          </div>
        </div>
        <div class="upozorneni">
          <p>
            Změny v odchodech musí být nahlášeny předem písemně. <strong
              >Telefonické uvolnění není možné.</strong>
          </p>
        </div>
      </div>
      <div class="blok">
        <h2>Jak se zapsat</h2>
        <div class="zapis-kroky">
          <div class="krok">
            <span class="krok-cislo">1</span><div>
              <strong>Zápisní list</strong><p>
                Vyžádejte si ho od vychovatelky a vyplňte.
              </p>
            </div>
          </div>
          <div class="krok">
            <span class="krok-cislo">2</span><div>
              <strong>Nástup</strong><p>
                Možný nejdříve od 2. dne školního roku.
              </p>
            </div>
          </div>
          <div class="krok">
            <span class="krok-cislo">3</span><div>
              <strong>Rozhodnutí ředitele</strong><p>
                V případě nepřijetí budete písemně informováni.
              </p>
            </div>
          </div>
          <div class="krok">
            <span class="krok-cislo">4</span><div>
              <strong>Odhlášení</strong><p>Pouze na základě písemné žádosti.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- POPLATKY + DOKUMENTY -->
    <section class="sekce dvousloupec">
      <div class="blok">
        <h2>Poplatky</h2>
        <p class="sekce-uvod">
          Výše úplaty je stanovena na začátku školního roku. Platit lze:
        </p>
        <div class="poplatky-grid">
          <div class="poplatek-item">
            <strong>Měsíčně</strong><p>Do 15. dne v měsíci</p>
          </div>
          <div class="poplatek-item">
            <strong>Pololetně</strong><p>Do 15. 9. a 15. 2.</p>
          </div>
          <div class="poplatek-item">
            <strong>Ročně</strong><p>Do 15. září</p>
          </div>
        </div>
        <p class="poznamka">
          Převodem nebo hotově v kanceláři. O snížení lze požádat v případě
          hmotné nouze, příspěvku na péči nebo pěstounské péče.
        </p>
      </div>
      <div class="blok">
        <h2>Ke stažení</h2>
        <div class="dokumenty-list">
          <a
            href="https://zs.walsem.cz/files/dokumenty/skolni-druzina-a-detsky-klub/1662279277_vn-rad-dws.pdf"
            target="_blank"
            class="dokument-link"
          >
            Vnitřní řád školní družiny
          </a>
          <a
            href="https://zs.walsem.cz/files/dokumenty/skolni-druzina-a-detsky-klub/svp-dws.pdf?819cbf5a96"
            target="_blank"
            class="dokument-link"
          >
            Školní vzdělávací program pro družiny
          </a>
          <a
            href="https://zs.walsem.cz/files/dokumenty/skolni-druzina-a-detsky-klub/1771840100_zapisovy-listek.pdf?88dbebd965"
            target="_blank"
            class="dokument-link"
          >
            Zápisový lístek
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* BREADCRUMB */
  .breadcrumb {
    position: relative;
    padding: 3rem 6rem;
    font-size: 17px;
    font-weight: 600;
    color: #1a1a1a;
    z-index: 1;
  }

  .breadcrumb a {
    text-decoration: none;
    color: #1a1a1a;
  }

  .breadcrumb a:hover {
    color: var(--cervena);
  }

  /* WRAPPER s mandálou */
  .druzina-wrapper {
    position: relative;
    max-width: 100vw;
  }

  .druzina-bg {
    position: absolute;
    top: -200px;
    left: 50%;
    width: 2400px;
    height: auto;
    object-fit: contain;
    z-index: 0;
    transform: translate(-43%, -6%) rotate(-150deg);
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  /* HERO */
  .druzina-hero {
    position: relative;
    z-index: 1;
    padding: 2rem 0 6rem;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    gap: 3rem;
  }

  .druzina-hero h1 {
    font-family: Waldorf;
    font-size: 90px;
    line-height: 1.2;
    flex-shrink: 0;
    max-width: 500px;
  }

  .druzina-vedlejsi {
    padding-top: 9rem;
    padding-left: 6rem;
  }

  .druzina-hero p {
    font-size: 20px;
    font-weight: 600;
    line-height: 1.6;
    max-width: 600px;
  }

  /* SEKCE */
  .sekce {
    position: relative;
    z-index: 1;
    padding: 3rem 8rem;
  }

  .sekce-alt {
    background: var(--cervena-svetla);
  }

  .dvousloupec {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .blok h2 {
    font-family: Waldorf;
    font-size: 40px;
    margin-bottom: 1.5rem;
  }

  .sekce-uvod {
    font-size: 17px;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .poznamka {
    font-size: 17px;
    color: #555;
    line-height: 1.6;
    margin-top: 1rem;
  }

  /* PROVOZ */
  .provoz-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .provoz-karta {
    background: var(--cervena-svetla);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .provoz-cas {
    font-family: Waldorf;
    font-size: 28px;
    display: block;
    margin-bottom: 0.4rem;
  }

  .provoz-karta p {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.5;
  }

  /* VYZVEDÁVÁNÍ */
  .vyzvednuti-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .vyzvednuti-item {
    background: white;
    border-radius: 10px;
    padding: 0.9rem 1rem;
    background-color: #fdf8f5;
  }

  .vyzvednuti-item span {
    font-size: 20px;
    font-weight: 600;
    display: block;
    margin-bottom: 0.25rem;
  }

  .vyzvednuti-item p {
    font-size: 17px;
    line-height: 1.4;
  }

  .upozorneni {
    background: rgba(176, 0, 48, 0.08);
    border-left: 4px solid var(--cervena);
    border-radius: 0 10px 10px 0;
    padding: 0.9rem 1.1rem;
  }

  .upozorneni p {
    font-size: 17px;
    line-height: 1.5;
  }

  /* ZÁPIS */
  .zapis-kroky {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .krok {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: white;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    background-color: #fdf8f5;
  }

  .krok-cislo {
    font-family: Waldorf;
    font-size: 40px;
    line-height: 1;
    flex-shrink: 0;
    width: 2rem;
  }

  .krok strong {
    display: block;
    font-size: 17px;
    margin-bottom: 0.2rem;
  }

  .krok p {
    font-size: 17px;
    line-height: 1.5;
    color: #444;
  }

  /* POPLATKY */
  .poplatky-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .poplatek-item {
    background: var(--cervena-svetla);
    border-radius: 12px;
    padding: 1.1rem;
  }

  .poplatek-item strong {
    font-family: Waldorf;
    font-size: 25px;
    display: block;
    margin-bottom: 0.3rem;
  }

  .poplatek-item p {
    font-size: 17px;
    line-height: 1.5;
  }

  /* DOKUMENTY */
  .dokumenty-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .dokument-link {
    display: block;
    text-decoration: none;
    color: #1a1a1a;
    background: var(--cervena-svetla);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    font-size: 17px;
    font-weight: 600;
    transition: background 0.2s;
  }

  .dokument-link:hover {
    color: var(--cervena);
  }

  /* RESPONZIVITA */
  @media (max-width: 1024px) {
    .breadcrumb {
      padding: 2rem 3rem;
    }

    .druzina-hero {
      padding: 2rem 3rem 4rem;
    }

    .druzina-hero h1 {
      font-size: 60px;
    }

    .sekce {
      padding: 2.5rem 3rem;
    }

    .dvousloupec {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .blok h2 {
      font-size: 32px;
    }
  }

  @media (max-width: 768px) {
    .breadcrumb {
      padding: 1.5rem;
    }

    .druzina-hero {
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem 1.5rem 3rem;
    }

    .druzina-vedlejsi {
      padding-top: 0;
      padding-left: 0;
    }

    .druzina-hero h1 {
      font-size: 44px;
    }

    .druzina-hero p {
      font-size: 17px;
    }

    .sekce {
      padding: 2rem 1.5rem;
    }

    .provoz-grid {
      grid-template-columns: 1fr;
    }

    .poplatky-grid {
      grid-template-columns: 1fr;
    }

    .vyzvednuti-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
