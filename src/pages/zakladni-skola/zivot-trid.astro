        padding: 1.5rem;
      }
      .zivot-hero {
        padding: 1.5rem 1.5rem 2rem;
      }
      .zivot-hero h1 {
        font-size: 44px;
      }
      .zivot-hero p {
        font-size: 16px;
      }
      .tridy {
        padding: 0 1.5rem 3rem;
      }
      .trida-cislo {
        font-size: 28px;
      }
    }
  </style>

  <script is:inline>
    document.querySelectorAll(".trida-toggle").forEach((toggle) => {
      toggle.addEventListener("click", () => {
        const obsah = toggle.nextElementSibling;
        const sipka = toggle.querySelector(".sipka");
        obsah.classList.toggle("otevreno");
        sipka.classList.toggle("otevreno");
      });
    });
  </script>
